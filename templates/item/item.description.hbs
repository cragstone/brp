{{! Description Tab }}
<section class='item tab description {{tab.cssClass}}' data-group='primary' data-tab='description'>
  <div class="bold">{{localize 'BRP.description'}}</div>
  {{! Editor for description}}
  <div class="description-doc">
    {{#if editable}}
      <prose-mirror name="system.description" value="{{system.description}}" editable="{{editable}}" toggled="false">
        {{{enrichedDescription}}}
      </prose-mirror>
    {{else}}
      {{{enrichedDescription}}}
    {{/if}}
  </div>
</section>